FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
        iproute2 \
        iptables \
        iputils-ping \
        nano \
        netcat-openbsd \
        sudo \
        tcpdump \
        vim \
        && rm -rf /var/lib/apt/lists/*

RUN echo "ubuntu:ubuntu" | chpasswd

USER ubuntu
WORKDIR /home/ubuntu
